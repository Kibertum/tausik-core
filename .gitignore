# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Environment files (secrets)
.env
.env.*

# Private keys
*.pem
*.key

# TAUSIK project data — all runtime, generated by bootstrap
.tausik/
.frai/

# RAG index data (local, machine-specific)
.rag/

# Generated IDE directories — bootstrap output, not source
.claude/
.claude-project/
.cursor/
.windsurf/
.codex/
.qwen/

# MCP config — generated by bootstrap with machine-specific paths
.mcp.json
.cursorrules

# Vendor skills config — user-specific, copied from skills.example.json
skills.json

# Official skills — separate repo (github.com/Kibertum/tausik-skills)
skills-official/

# Databases (other)
*.sqlite

# Logs
*.log

# Temp
temp/
nul

# Backup files
*.bak*
.tausik/*.bak.*

# Archives
*.tar.gz

# Coverage / pytest / linter caches (all regenerable)
.coverage
.coverage.*
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Review reports
REVIEW-REPORT-*.md

# tausik.tech docs site (VitePress monorepo) — ignore build artefacts only, source tracked.
site/node_modules/
site/.vitepress/cache/
site/.vitepress/dist/
# Generated by scripts/sync-docs.mjs (canonical source is docs/{en,ru}/)
site/docs/
site/ru/docs/
# Claude Design export drop-zone (re-generatable from site/brief.md)
site/public/uploads/
site/tausik.zip
