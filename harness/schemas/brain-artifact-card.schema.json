{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tausik.local/schemas/brain-artifact-card.schema.json",
  "title": "Shared Brain artifact card (logical)",
  "description": "Validated pattern/gotcha payload for MCP/API before Notion write. Fields not listed are ignored by validators in v1. Optional omit of `scope` is allowed unless brain.require_artifact_scope is true in config.",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "artifact_taxonomy_kind": {
      "type": "string",
      "enum": ["artifact", "pattern", "snippet"]
    },
    "when_to_use": { "type": "string" },
    "wrong_way": { "type": "string" },
    "right_way": { "type": "string" },
    "example": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
    "confidence": {
      "type": "string",
      "enum": ["experimental", "tested", "proven"]
    },
    "evidence_url": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "stack": { "type": "array", "items": { "type": "string" } },
    "date": { "type": "string" },
    "project_name": { "type": "string" },
    "external_repo_url": {
      "type": "string",
      "minLength": 1,
      "description": "Optional https URL for canonical repo / submodule reference (validated server-side; not persisted to Notion props in v1)."
    }
  }
}
